# Puerto HTTP del servidor (también configurable en Configuración → Empresa y Límites)
PORT=3000

# URL pública al exponer con Cloudflare Tunnel u otro proxy (opcional).
# Ejemplo: https://mi-erp.midominio.com o https://xxxx.trycloudflare.com
# PUBLIC_BASE_URL=

# Orígenes extra permitidos por CORS (separados por coma), para dominios propios en túnel.
# CORS_ORIGINS=https://erp.midominio.com

# Gemini API (Google AI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
